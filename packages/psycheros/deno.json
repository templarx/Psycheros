{
  "name": "@psycheros/daemon",
  "version": "0.7.2",
  "exports": "./src/main.ts",
  "imports": {
    "marked": "npm:marked@^15",
    "sanitize-html": "npm:sanitize-html@^2",
    "pdf-parse": "npm:pdf-parse@^1.1.1",
    "mammoth": "npm:mammoth@^1.8.0",
    "xlsx": "npm:xlsx@^0.18.5",
    "web-push": "npm:web-push@^3.6",
    "@zendrex/buttplug.js": "npm:@zendrex/buttplug.js@^0.3",
    "emojilib": "npm:emojilib@^3"
  },
  "tasks": {
    "dev": "deno run --watch --watch-exclude=identity/ -A src/main.ts",
    "start": "deno run -A src/main.ts",
    "stop": "pkill -INT -f 'deno.*main.ts' || true"
  },
  "lint": {
    "exclude": [
      "web/lib/",
      "web/js/"
    ],
    "rules": {
      "exclude": [
        "require-await"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "web/lib/",
      "web/js/"
    ]
  }
}
