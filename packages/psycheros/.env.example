# Psycheros Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required: Z.ai API Configuration
# =============================================================================

# Your Z.ai API key (required)
ZAI_API_KEY=your-api-key-here

# =============================================================================
# Optional: Z.ai API Settings
# =============================================================================

# Base URL for the Z.ai API (default: https://api.z.ai/api/paas/v4/chat/completions)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions

# Model to use (default: glm-4.7)
# ZAI_MODEL=glm-4.7

# Worker model for lightweight tasks like auto-titling (default: GLM-4.5-Air)
# ZAI_WORKER_MODEL=GLM-4.5-Air

# =============================================================================
# Optional: Server Configuration
# =============================================================================

# Port to run the server on (default: 3000)
# PSYCHEROS_PORT=3000

# Host to bind to (default: 0.0.0.0)
# PSYCHEROS_HOST=0.0.0.0

# =============================================================================
# Optional: Debug SSH (Docker only)
# =============================================================================
# In-container SSH server for live debugging (e.g. an external Claude Code
# agent connecting to diagnose a production container). Disabled by default.
# Key-based auth only — sshd refuses to start without authorized keys.
#
# When enabling, you must also map the port at `docker run -p <host>:<port>`.

# Enable the in-container sshd (default: false)
# PSYCHEROS_SSH_ENABLED=true

# Port sshd listens on inside the container (default: 47291)
# PSYCHEROS_SSH_PORT=47291

# Authorized public keys. Multiple keys are separated by COMMAS (not newlines —
# UnRAID and many container UIs strip newlines from env var values). Each comma-
# separated entry is one full key line. Alternatively, mount a file at
# /root/.ssh/authorized_keys. The env var takes precedence if set.
# PSYCHEROS_SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAA... operator@laptop,ssh-ed25519 BBBB... agent@home"

# =============================================================================
# Optional: Appearance
# =============================================================================

# Primary accent color (default: #39ff14 phosphor green)
# Examples: #ff6b6b (coral), #4ecdc4 (teal), #ffb000 (amber), #00ffff (cyan)
# PSYCHEROS_ACCENT_COLOR=#39ff14

# =============================================================================
# Optional: Tool Access Control
# =============================================================================

# Comma-separated list of tools the entity is allowed to use.
# When unset (or empty) every non-deprecated tool is enabled. Use
# PSYCHEROS_TOOLS=none to disable all non-auto tools, or list specific tools to
# constrain the surface.
#
# Available tools:
#   shell                      - Execute shell commands (powerful but potentially dangerous)
#   update_title               - Update the current conversation's title
#   create_significant_memory  - Create a permanent emotionally-significant memory
#   get_metrics                - Retrieve streaming performance metrics
#   sync_mcp                   - Manually sync with entity-core
#   maintain_identity          - Full identity file maintenance
#   list_identity_snapshots    - View available identity backups
#   custom_identity_file       - Create and manage custom identity files
#   vault                      - Store and retrieve documents from the data vault
#   web_search                 - Search the web for current information
#   pulse                      - Create, trigger, and delete scheduled autonomous prompts
#   send_discord_dm            - Send Discord direct messages
#   control_device             - Control smart home devices
#   control_lovense            - Control Lovense devices
#   control_toy                - Control universal protocol toys (Intiface/Buttplug)
#   generate_image             - Generate images
#   describe_image             - Caption and describe images
#   look_closer                - Re-examine images for detailed descriptions
#
# Examples:
#   PSYCHEROS_TOOLS=update_title                        # Enable only title updates
#   PSYCHEROS_TOOLS=shell,update_title                  # Enable multiple tools
#   PSYCHEROS_TOOLS=shell,update_title,create_significant_memory
#   PSYCHEROS_TOOLS=                                    # All tools (default)
#   PSYCHEROS_TOOLS=none                                # No non-auto tools
#
# PSYCHEROS_TOOLS=update_title

# =============================================================================
# Optional: RAG (Retrieval-Augmented Generation) Configuration
# =============================================================================

# Enable RAG for memory retrieval (default: true)
# PSYCHEROS_RAG_ENABLED=true

# Maximum number of memory chunks to retrieve (default: 8)
# PSYCHEROS_RAG_MAX_CHUNKS=8

# Maximum token budget for retrieved content (default: 2000)
# PSYCHEROS_RAG_MAX_TOKENS=2000

# Minimum relevance score (0-1) for including memories (default: 0.3)
# PSYCHEROS_RAG_MIN_SCORE=0.3

# =============================================================================
# Optional: MCP Integration (entity-core)
# =============================================================================

# Enable connection to entity-core MCP server (default: true)
# Set to "false" to disable.
# PSYCHEROS_MCP_ENABLED=true

# Command to spawn entity-core (default: deno)
# PSYCHEROS_MCP_COMMAND=deno

# Path to entity-core repository root (default: ../entity-core relative to Psycheros)
# Only needed if entity-core is not a sibling directory of Psycheros.
# PSYCHEROS_ENTITY_CORE_PATH=/path/to/entity-core

# Arguments for entity-core (default: run -A <entity-core-path>/src/mod.ts)
# PSYCHEROS_MCP_ARGS=run -A /path/to/entity-core/src/mod.ts

# Instance ID for this embodiment (default: psycheros)
# PSYCHEROS_MCP_INSTANCE=psycheros

# Data directory for entity-core (default: <entity-core-path>/data)
# PSYCHEROS_ENTITY_CORE_DATA_DIR=/path/to/entity-core/data

# Where Psycheros writes user-mutable runtime state (.psycheros/, identity/,
# .snapshots/, memories/, custom-tools/, backgrounds/). Defaults to the current
# working directory, which preserves today's `deno task start` behaviour.
# Set this when a launcher or container points source and data at different
# locations (e.g. the desktop app puts data under
# ~/Library/Application Support/Psycheros/).
# PSYCHEROS_DATA_DIR=/path/to/psycheros-data

# Override LLM settings for entity-core's knowledge graph extraction.
# These fall back to ZAI_* vars above if not set. In most cases you don't need these.
# ENTITY_CORE_LLM_API_KEY=
# ENTITY_CORE_LLM_BASE_URL=
# ENTITY_CORE_LLM_MODEL=
# ENTITY_CORE_LLM_TEMPERATURE=0.3
# ENTITY_CORE_LLM_MAX_TOKENS=8000

# =============================================================================
# Optional: Timezone
# =============================================================================

# Timezone for message timestamps and cron scheduling (default: UTC)
# Examples: America/Los_Angeles, America/New_York, Europe/London
# TZ=UTC

# Display timezone — overrides TZ for UI timestamp formatting and shifts daily
# summarization to 5 AM in this zone. Normally set from Settings > Appearance
# in the web UI; setting it here only changes the bootstrap default.
# PSYCHEROS_DISPLAY_TZ=

# =============================================================================
# Optional: Memory System
# =============================================================================

# Hour to run daily summarization (fallback when PSYCHEROS_DISPLAY_TZ is not set)
# When PSYCHEROS_DISPLAY_TZ is set, daily memories use 5 AM in that timezone instead.
# PSYCHEROS_MEMORY_HOUR=4

# =============================================================================
# Optional: Snapshot System
# =============================================================================

# Hour to run daily identity snapshots (default: 3, meaning 3 AM)
# PSYCHEROS_SNAPSHOT_HOUR=3
#
# Retention for identity snapshots is controlled by entity-core, not Psycheros.
# See ENTITY_CORE_SNAPSHOT_RETENTION_DAYS in packages/entity-core/.env.example.

# =============================================================================
# Optional: Web Search
# =============================================================================

# Web search provider (default: disabled)
# Options: disabled, tavily, brave
#   disabled - No web search capability
#   tavily   - Uses Tavily API (requires TAVILY_API_KEY)
#   brave    - Uses Brave Search API (requires BRAVE_SEARCH_API_KEY)
# PSYCHEROS_WEB_SEARCH=disabled

# Tavily API key (required if PSYCHEROS_WEB_SEARCH=tavily)
# Get one at https://tavily.com
# TAVILY_API_KEY=

# Brave Search API key (required if PSYCHEROS_WEB_SEARCH=brave)
# Get one at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=

# =============================================================================
# Optional: External Connections
# =============================================================================

# Discord bot token for sending DMs
# Create a bot at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# Default Discord channel/user ID to send DMs to
# DISCORD_DEFAULT_CHANNEL_ID=
